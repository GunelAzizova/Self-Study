# LEVEL 7 — ADVANCED: FULL PRODUCTION SCRAPER
# ════════════════════════════════════════════════════════════
#
#   A real scraper used in production needs:
#   ✓ Retry logic       (handle network failures automatically)
#   ✓ Logging           (know what happened when you weren't watching)
#   ✓ Error handling    (don't crash on one bad page)
#   ✓ Rotating delays   (don't get banned)
#   ✓ Data validation   (make sure scraped data makes sense)
#   ✓ Export            (CSV, JSON, or direct to a database)

import logging
from dataclasses import dataclass

# Set up a logger (writes messages with timestamps)
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.StreamHandler(),              # print to terminal
        logging.FileHandler("scraper.log"),   # also write to a file
    ]
)
log = logging.getLogger(__name__)


@dataclass
class Book:
    """A structured data container for one book."""
    title:      str
    price:      float
    rating:     int
    url:        str

    def is_valid(self) -> bool:
        """Basic validation — reject clearly broken records."""
        return (
            bool(self.title) and
            self.price > 0 and
            1 <= self.rating <= 5
        )


class BookScraper:
    """
    A production-ready scraper class.

    Using a class lets you:
    - Keep shared settings in one place (base_url, session, delays)
    - Separate concerns (fetching, parsing, saving are different methods)
    - Easily extend or test individual parts
    """

    BASE_URL    = "https://books.toscrape.com/catalogue/"
    START_URL   = "https://books.toscrape.com/catalogue/page-1.html"
    RATING_MAP  = {"One": 1, "Two": 2, "Three": 3, "Four": 4, "Five": 5}
    DELAY_RANGE = (1.0, 3.0)    # seconds between requests
    MAX_RETRIES = 3              # how many times to retry a failed page

    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update(HEADERS)

    # ── Private: fetch one URL with retry logic ───────────────
    def _fetch(self, url: str) -> BeautifulSoup | None:
        for attempt in range(1, self.MAX_RETRIES + 1):
            try:
                resp = self.session.get(url, timeout=10)
                resp.raise_for_status()  # raises exception for 4xx/5xx
                return BeautifulSoup(resp.text, "lxml")
            except requests.RequestException as err:
                log.warning("Attempt %d/%d failed for %s: %s",
                            attempt, self.MAX_RETRIES, url, err)
                if attempt < self.MAX_RETRIES:
                    time.sleep(2 ** attempt)  # wait 2s, then 4s, then 8s
        log.error("All retries exhausted for %s", url)
        return None  # return None so the caller can skip this page

    # ── Private: parse one book article tag ──────────────────
    def _parse_book(self, article) -> Book | None:
        try:
            price_text = (
                article.find("p", class_="price_color")
                .text.strip()
                .replace("£", "")
                .replace("Â", "")
            )
            rating_word = article.find("p", class_="star-rating")["class"][1]
            href = article.find("h3").find("a")["href"]

            return Book(
                title  = article.find("h3").find("a")["title"],
                price  = float(price_text),
                rating = self.RATING_MAP.get(rating_word, 0),
                url    = self.BASE_URL + href,
            )
        except Exception as err:
            log.warning("Could not parse a book: %s", err)
            return None  # skip this book, keep going

    # ── Public: run the full scraper ─────────────────────────
    def run(self, max_pages: int = 5) -> pd.DataFrame:
        log.info("Starting scrape (max %d pages)", max_pages)
        books: list[Book] = []
        current_url = self.START_URL
        page = 1

        while current_url and page <= max_pages:
            log.info("Page %d → %s", page, current_url)
            soup = self._fetch(current_url)

            if soup is None:
                log.error("Skipping page %d due to repeated failures", page)
                break

            for article in soup.find_all("article", class_="product_pod"):
                book = self._parse_book(article)
                if book and book.is_valid():
                    books.append(book)
                else:
                    log.debug("Dropped invalid book record")

            # Find next page
            next_btn = soup.find("li", class_="next")
            current_url = (self.BASE_URL + next_btn.find("a")["href"]
                           if next_btn else None)
            page += 1

            delay = random.uniform(*self.DELAY_RANGE)
            log.info("  Waiting %.1f seconds …", delay)
            time.sleep(delay)

        log.info("Done. Collected %d valid books.", len(books))
        return pd.DataFrame([b.__dict__ for b in books])

    # ── Public: save results ──────────────────────────────────
    def save(self, df: pd.DataFrame, path: str = "books_final.csv"):
        df.to_csv(path, index=False)
        log.info("Saved %d rows to %s", len(df), path)


# ── Run the production scraper ───────────────────────────────
print("\n\n── Running production scraper ─────────────────")
scraper = BookScraper()
df = scraper.run(max_pages=2)
scraper.save(df)

print("\nFinal dataset:")
print(df[["title", "price", "rating"]].head(10))

print("\n── Quick analysis ─────────────────────────────")
print("Average price:  £", round(df["price"].mean(), 2))
print("Average rating:", round(df["rating"].mean(), 2))
print("Books per rating:\n", df["rating"].value_counts().sort_index())


