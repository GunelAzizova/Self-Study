# ════════════════════════════════════════════════════════════
# LEVEL 0 — HOW WEBSITES WORK (READ THIS FIRST!)
# ════════════════════════════════════════════════════════════
#
#   When you open a website in your browser, here is what happens:
#
#   1. Your browser sends a REQUEST  →  "Give me google.com"
#   2. The server sends back a RESPONSE  →  HTML text (the page)
#   3. Your browser RENDERS the HTML  →  You see the pretty page
#
#   Web scraping = step 1 and 2, but in Python, not a browser.
#   We download the HTML text, then find the data we want inside it.
#
#   WHAT IS HTML?
#   HTML is the language of web pages. Every piece of content
#   lives inside "tags" like these:
#
#   <h1>Big Title</h1>               ← heading
#   <p>Some paragraph text.</p>      ← paragraph
#   <a href="https://...">Click</a>  ← link
#   <div class="price">$29.99</div>  ← a container (very common)
#   <table><tr><td>Cell</td></tr></table> ← a table
#
#   HOW TO FIND THE RIGHT HTML TAG:
#   1. Open any website in Chrome or Firefox
#   2. Right-click on the text you want  →  "Inspect"
#   3. The DevTools panel shows you the exact HTML tag
#   4. Copy the tag name, class, or id — then use it in your code


# ════════════════════════════════════════════════════════════
# LEVEL 1 — DOWNLOAD A PAGE  (requests)
# ════════════════════════════════════════════════════════════

import requests

# ── What is a response? ──────────────────────────────────────
# requests.get() sends a GET request to a URL, just like your browser.
# We use a safe practice site made for scraping learners.

url = "https://books.toscrape.com"
response = requests.get(url)

# The response object has several useful attributes:
print("Status code:", response.status_code)
# 200 = OK,  404 = Not Found,  403 = Forbidden,  429 = Too Many Requests

print("Content type:", response.headers["Content-Type"])
# text/html → it's a webpage    application/json → it's an API response

# The actual HTML text (first 500 characters so we don't flood the screen)
print("\nFirst 500 chars of HTML:")
print(response.text[:500])


# ── Always check status before continuing ────────────────────
if response.status_code == 200:
    print("\nPage downloaded successfully ✓")
else:
    print(f"Something went wrong: {response.status_code}")


# ════════════════════════════════════════════════════════════
# LEVEL 2 — PARSE HTML  (BeautifulSoup)
# ════════════════════════════════════════════════════════════
#
#   BeautifulSoup turns raw HTML text into a navigable object
#   so you can search for specific tags, classes, and text.
#
#   MAIN METHODS:
#   soup.find("tag")               → first match
#   soup.find("tag", class_="x")  → first match with that class
#   soup.find_all("tag")          → ALL matches as a list
#   element.text                  → the visible text inside a tag
#   element["href"]               → the value of an attribute

from bs4 import BeautifulSoup

response = requests.get("https://books.toscrape.com")
soup = BeautifulSoup(response.text, "lxml")
# "lxml" is the HTML parser (engine). It's fast and forgiving of bad HTML.


# ── Find a single element ────────────────────────────────────
title = soup.find("title")
print("\nPage title tag:", title)        # <title>All products | ...</title>
print("Page title text:", title.text)   # All products | ...


# ── Find all elements of the same type ───────────────────────
# Each book on the page is inside an <article class="product_pod"> tag
books = soup.find_all("article", class_="product_pod")
print(f"\nFound {len(books)} books on this page")


# ── Extract data from each element ───────────────────────────
print("\n── First 3 books ──────────────────────────────")
for book in books[:3]:

    # Book title is inside <h3><a title="...">
    title = book.find("h3").find("a")["title"]

    # Price is inside <p class="price_color">
    price = book.find("p", class_="price_color").text.strip()

    # Rating is a CSS class like "One", "Two", "Three"...
    rating_class = book.find("p", class_="star-rating")["class"]
    rating = rating_class[1]  # e.g. ["star-rating", "Three"] → "Three"

    print(f"  {title[:40]:<40} {price}  ★ {rating}")


# ════════════════════════════════════════════════════════════
# LEVEL 3 — SCRAPE MULTIPLE PAGES  (pagination)
# ════════════════════════════════════════════════════════════
#
#   Most websites split results across multiple pages.
#   We need to detect the "Next" button and follow it.

import time
import random
import pandas as pd

def scrape_books(max_pages: int = 3) -> pd.DataFrame:
    """
    Scrapes books from books.toscrape.com across multiple pages.
    Returns a clean DataFrame.
    """
    base_url = "https://books.toscrape.com/catalogue/"
    current_url = "https://books.toscrape.com/catalogue/page-1.html"
    all_books = []
    page_num = 1

    while current_url and page_num <= max_pages:
        print(f"  Scraping page {page_num} → {current_url}")

        response = requests.get(current_url)
        soup = BeautifulSoup(response.text, "lxml")

        # ── Extract all books on this page ───────────────────
        for book in soup.find_all("article", class_="product_pod"):
            all_books.append({
                "title":  book.find("h3").find("a")["title"],
                "price":  book.find("p", class_="price_color").text.strip(),
                "rating": book.find("p", class_="star-rating")["class"][1],
                "link":   base_url + book.find("h3").find("a")["href"],
            })

        # ── Find the "next" button ────────────────────────────
        next_btn = soup.find("li", class_="next")
        if next_btn:
            next_href = next_btn.find("a")["href"]
            current_url = base_url + next_href
        else:
            current_url = None  # no more pages, stop the loop

        page_num += 1

        # ── BE POLITE: wait between requests ─────────────────
        # Random delay between 1 and 3 seconds.
        # Without this you may get blocked or harm the server.
        time.sleep(random.uniform(1, 3))

    df = pd.DataFrame(all_books)
    return df


print("\n── Scraping books (3 pages) ───────────────────")
books_df = scrape_books(max_pages=3)
print(f"Collected {len(books_df)} books\n")
print(books_df.head())


# ── Clean the data ───────────────────────────────────────────
# Convert price from "£12.99" string → 12.99 float
books_df["price_num"] = (
    books_df["price"]
    .str.replace("£", "", regex=False)
    .str.replace("Â", "", regex=False)   # encoding artifact
    .astype(float)
)

# Convert rating from word → number
rating_map = {"One": 1, "Two": 2, "Three": 3, "Four": 4, "Five": 5}
books_df["rating_num"] = books_df["rating"].map(rating_map)

# Save to CSV (your portable data file)
books_df.to_csv("books.csv", index=False)
print("\nData saved to books.csv ✓")


# ════════════════════════════════════════════════════════════
# LEVEL 4 — LOOK LIKE A REAL BROWSER  (headers + sessions)
# ════════════════════════════════════════════════════════════
#
#   Some websites block Python scrapers immediately.
#   You can avoid this by:
#   1. Sending real browser "headers" with your request
#   2. Using a Session (keeps cookies, like a logged-in browser)

# ── Headers ──────────────────────────────────────────────────
# By default requests sends "python-requests/2.x" as User-Agent.
# Websites see that and know it's a bot. Send browser headers instead.

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/124.0.0.0 Safari/537.36"
    ),
    "Accept-Language": "en-US,en;q=0.9",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
    "Referer": "https://www.google.com/",  # pretend you came from Google
}

# ── Session ──────────────────────────────────────────────────
# A Session reuses the same connection and keeps cookies automatically.
# This is how you stay "logged in" while scraping multiple pages.

session = requests.Session()
session.headers.update(HEADERS)

response = session.get("https://books.toscrape.com")
print("\nWith session + headers:", response.status_code)

# For sites that need login:
# session.post("https://example.com/login", data={"user": "me", "pass": "123"})
# session.get("https://example.com/private-page")  ← now you're authenticated


# ════════════════════════════════════════════════════════════
# LEVEL 5 — SCRAPE APIS  (JSON responses)
# ════════════════════════════════════════════════════════════
#
#   Modern websites load data via hidden API calls.
#   In your browser DevTools → Network tab → Filter "Fetch/XHR"
#   You'll see JSON requests — these are MUCH easier to scrape
#   than HTML because the data is already structured.
#
#   HOW TO FIND THEM:
#   1. Open DevTools (F12)  →  Network tab
#   2. Reload the page or click around
#   3. Look for requests returning JSON data
#   4. Copy that URL into your Python code

# Example: Open-Meteo is a free weather API (no key needed)
def get_weather(city_lat: float, city_lon: float) -> dict:
    url = "https://api.open-meteo.com/v1/forecast"
    params = {
        "latitude":   city_lat,
        "longitude":  city_lon,
        "current":    "temperature_2m,wind_speed_10m",
        "timezone":   "auto",
    }
    response = requests.get(url, params=params)
    return response.json()  # .json() parses the JSON automatically


weather = get_weather(40.7128, -74.0060)  # New York
print("\n── Weather API example ────────────────────────")
print("Temperature:", weather["current"]["temperature_2m"], "°C")
print("Wind speed:",  weather["current"]["wind_speed_10m"], "km/h")


